rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Вспомогательные функции ───────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Родитель ребёнка: auth.uid ∈ parentUids ДОКА РЕБЁНКА (вариант B).
    // childUids родителя НЕ используем для авторизации (self-write обходит).
    // get() в rules привилегированный — читает parentUids без открытия users/{child}.
    function isParentOf(studentUid) {
      return isSignedIn()
        && request.auth.uid in
           get(/databases/$(database)/documents/users/$(studentUid)).data.get('parentUids', []);
    }

    // ── Публичные профили (denorm-зеркало users/{uid}) ───────────────────────
    // Пишет только Cloud Function mirrorUserToPublicProfile через Admin SDK
    // (обходит rules). Клиенты только читают.
    match /publicProfiles/{userId} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // ── Пользователи ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get:    if isOwner(userId) || isAdmin();
      allow list:   if isAdmin();
      allow create: if isOwner(userId);
      // Self-update: всё кроме role/status. Crystals — целое ≥ 0; верхняя
      // граница `old + 200` сохраняет anti-cheat earn-ceiling. Decrement
      // разрешён (для покупок в магазине) — нижняя граница только ≥ 0.
      allow update: if isAdmin() || (
                      isOwner(userId)
                      && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'childUids', 'parentUids', 'telegramLink'])
                      && (
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['crystals'])
                        || (
                          request.resource.data.crystals is int
                          && request.resource.data.crystals >= 0
                          && request.resource.data.crystals <= resource.data.get('crystals', 0) + 200
                        )
                      )
                      // XP — целое, только растёт; верхняя граница `old + 500`
                      // обрезает тривиальный DevTools-абюз (одно действие ≤ 200 XP).
                      && (
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['xp'])
                        || (
                          request.resource.data.xp is int
                          && request.resource.data.xp >= resource.data.get('xp', 0)
                          && request.resource.data.xp <= resource.data.get('xp', 0) + 500
                        )
                      )
                    ) || (
                      // Unfriend: НЕ-владелец может удалить РОВНО СВОЙ uid из
                      // чужого массива friends (обоюдное удаление дружбы без
                      // Cloud Function). Ничего другого менять нельзя.
                      isSignedIn() && request.auth.uid != userId
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends'])
                      && resource.data.get('friends', []).toSet().difference(request.resource.data.get('friends', []).toSet()) == [request.auth.uid].toSet()
                      && request.resource.data.get('friends', []).toSet().difference(resource.data.get('friends', []).toSet()).size() == 0
                    );
      allow delete: if false;
    }

    // ── Коды приглашений: friendCodes/{code} = { uid } ───────────────────────
    // Резолв кода → uid при добавлении друга. Код не раскрывает личных данных.
    // Создаёт владелец uid (или Admin SDK миграцией); менять/удалять нельзя.
    match /friendCodes/{code} {
      allow get:    if isSignedIn();
      allow list:   if false;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasOnly(['uid'])
                    && code.matches('[0-9]{6}');
      allow update, delete: if false;
    }

    // ── Запросы дружбы: friendRequests/{autoId} ──────────────────────────────
    // create: только от своего имени, только pending. Акцепт/отклонение —
    // получатель; отметка seenByFrom — отправитель. Обоюдную запись friends
    // при акцепте делает Cloud Function onFriendRequestWritten.
    match /friendRequests/{reqId} {
      allow read:   if isSignedIn()
                    && (resource.data.fromUid == request.auth.uid
                        || resource.data.toUid == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.toUid is string
                    && request.resource.data.toUid != request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.seenByFrom == false
                    && request.resource.data.fromName is string
                    && request.resource.data.fromName.size() <= 80;
      allow update: if isSignedIn() && (
                      ( // получатель отвечает на pending
                        resource.data.toUid == request.auth.uid
                        && resource.data.status == 'pending'
                        && request.resource.data.status in ['accepted', 'declined']
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt'])
                      ) || (
                        // отправитель помечает «видел, что приняли»
                        resource.data.fromUid == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenByFrom'])
                        && request.resource.data.seenByFrom == true
                      )
                    );
      allow delete: if isSignedIn()
                    && (resource.data.fromUid == request.auth.uid
                        || resource.data.toUid == request.auth.uid);
    }

    // ── Коды привязки родителя: parentLinkCodes/{code} = { uid } ─────────────
    // Резолв кода → studentUid при привязке родителя. Ключ — 6 цифр (префикс
    // "P-" только в UI, в реестре не хранится). Создаёт владелец-ученик;
    // delete владельцем — для revoke (перегенерация при утечке кода).
    match /parentLinkCodes/{code} {
      allow get:    if isSignedIn();
      allow list:   if false;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasOnly(['uid'])
                    && code.matches('[0-9]{6}');
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── Запросы привязки родителя: parentLinkRequests/{autoId} ───────────────
    // Родитель создаёт запрос со своим uid + кодом ребёнка (status:'pending').
    // Двустороннюю связь (parent.childUids += studentUid, student.parentUids +=
    // parentUid) и доводку статуса (linked/invalid) делает Cloud Function
    // onParentLinkRequestWritten (Admin SDK обходит rules). Код = согласие
    // ученика (он сам показал код), отдельного акцепта нет.
    match /parentLinkRequests/{reqId} {
      allow read:   if isSignedIn() && resource.data.parentUid == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.parentUid == request.auth.uid
                    && request.resource.data.code is string
                    && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    // ── Запросы отвязки родителя: parentUnlinkRequests/{autoId} ──────────────
    // Родитель создаёт запрос {parentUid, childUid, status:'pending'}. Связь
    // снимает Cloud Function onParentUnlinkRequestWritten (arrayRemove обе
    // стороны, Admin SDK). self-write childUids/parentUids заблокирован (Шаг 4),
    // поэтому отвязка идёт только через Function.
    match /parentUnlinkRequests/{reqId} {
      allow read:   if isSignedIn() && resource.data.parentUid == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.parentUid == request.auth.uid
                    && request.resource.data.childUid is string
                    && request.resource.data.status == 'pending';
      allow update, delete: if false;   // только Cloud Function (Admin SDK)
    }

    // ── Коды привязки Telegram: telegramLinkCodes/{code} = { parentUid, expiresAt } ──
    // (Этап 2, фаза B) Резолв кода → РОДИТЕЛЬ (не ученик). Создаёт залогиненный
    // родитель со СВОИМ uid + TTL (expiresAt, epoch ms). Резолв/удаление при
    // привязке делает Cloud Function telegramWebhook (Admin SDK обходит rules).
    // get открыт для коллизия-чека при генерации (как parentLinkCodes/friendCodes;
    // код раскрывает лишь opaque parentUid). delete владельцем — revoke/перегенерация.
    match /telegramLinkCodes/{code} {
      allow get:    if isSignedIn();
      allow list:   if false;
      allow create: if isSignedIn()
                    && request.resource.data.parentUid == request.auth.uid
                    && request.resource.data.keys().hasOnly(['parentUid', 'expiresAt'])
                    && request.resource.data.expiresAt is int
                    && code.matches('[0-9]{6}');
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.parentUid == request.auth.uid;
    }

    // ── Запросы отвязки Telegram: telegramUnlinkRequests/{autoId} ─────────────
    // (Этап 2, фаза B4) Родитель создаёт { parentUid, status:'pending' }. Удаление
    // telegramLinks + сброс users.telegramLink делает Cloud Function
    // onTelegramUnlinkRequestWritten (Admin SDK). Отвязка parent-level (без childUid).
    match /telegramUnlinkRequests/{reqId} {
      allow read:   if isSignedIn() && resource.data.parentUid == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.parentUid == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update, delete: if false;   // только Cloud Function (Admin SDK)
    }

    // ── Привязки Telegram: telegramLinks/{chatId} = { parentUid, active, linkedAt } ──
    // (Этап 2, фаза B5) Пишет/читает ТОЛЬКО Cloud Function (telegramWebhook /
    // onTelegramUnlinkRequestWritten, Admin SDK обходит rules). Клиенту закрыто
    // полностью — статус привязки родитель видит через users.telegramLink (зеркало).
    match /telegramLinks/{chatId} {
      allow read, list, write: if false;
    }

    // ── Медали (субколлекция users/{uid}/medals/{medalId}) ──────────────────
    // Пишет только Cloud Function awardWeeklyMedals (Admin SDK обходит rules).
    // Читают — все залогиненные (медали отображаются в публичном профиле).
    match /users/{userId}/medals/{medalId} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // ── Достижения (субколлекция users/{uid}/achievements/{achId}) ──────────
    // Пишет только Cloud Functions (awardAchievement, Admin SDK обходит rules).
    // Читают — все залогиненные (достижения видны в профиле).
    match /users/{userId}/achievements/{achId} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // ── Настройки — только admin ──────────────────────────────────────────────
    match /settings/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Контент: залогиненные читают, только admin пишет ─────────────────────
    match /taskBank/{docId}          { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /skills/{docId}            { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /sections/{docId}          { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /questions/{docId}         { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /theories/{docId}          { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /topics/{docId}            { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /skillsDb/{docId}          { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /prereqMap/{docId}         { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /skillHierarchies/{docId}  { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /crossGradeLinks/{docId}   { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /skillTheory/{docId}       { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /skillTasks/{docId}        { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /dailyTasks/{docId}        { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /globalSkillMap/{docId}    { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // ── Прогресс учеников: ключ = uid ────────────────────────────────────────
    match /skillProgress/{userId} {
      allow read:   if isOwner(userId) || isAdmin() || isParentOf(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false;
      allow list:   if false;
    }

    match /skillMastery/{userId} {
      allow read:   if isOwner(userId) || isAdmin() || isParentOf(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false;
      allow list:   if false;
    }

    match /userProgress/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false;
      allow list:   if false;
    }

    match /individualPlans/{userId} {
      allow read:   if isOwner(userId) || isAdmin() || isParentOf(userId);
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false;
      allow list:   if false;
    }

    // ── Недельные снимки прогресса: progressSnapshots/{uid}/weeks/{weekId} ────
    // Пишет ТОЛЬКО Cloud Function weeklyProgressSnapshot (Admin SDK обходит rules).
    // Читает/листает владелец, admin, родитель (isParentOf по {uid}). list открыт —
    // дашборду нужен перечень недель для тренда (роста освоения).
    match /progressSnapshots/{uid}/weeks/{weekId} {
      allow read, list: if isOwner(uid) || isAdmin() || isParentOf(uid);
      allow write:      if false;
    }

    match /quizProgress/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
      allow list:   if false;
    }

    // ── Результаты диагностики: auto-ID, поле userId = uid ───────────────────
    match /diagnosticResults/{docId} {
      // Студент создаёт свой результат; читает свои; admin читает/пишет всё
      allow read:   if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Экспертные отчёты: только admin пишет, студент читает свои ───────────
    match /expertReports/{docId} {
      allow read:   if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Медали: студент создаёт свои, читает свои ─────────────────────────────
    match /medals/{docId} {
      allow read:   if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ── Сдача ДЗ: студент создаёт свою, admin проверяет ──────────────────────
    match /hwSubmissions/{docId} {
      allow read:   if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Домашние задания: admin создаёт, студент читает своё ─────────────────
    // homework.userId — uid студента, которому назначено (или "" — для всех)
    match /homework/{docId} {
      allow read: if isSignedIn()
                  && (isAdmin()
                      || resource.data.userId == request.auth.uid
                      || resource.data.userId == "");
      allow write: if isAdmin();
    }

    // ── Расписание: admin управляет, залогиненные читают ─────────────────────
    // schedule.userIds — массив uid (после миграции будет uid, сейчас legacy)
    match /schedule/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Уроки: Admin SDK пишет (обходит rules). Приватность: lessons содержат
    // driveVideoUrl (видео-запись урока ребёнка) + summary конкретного ученика →
    // НЕ broad read. Читают: владелец (studentId==uid), teacher (роль из users-doc),
    // admin. Owner-проверка ПЕРВОЙ → ученик не платит лишний get(/users) (частый случай).
    // Клиент: student шлёт scoped where(studentId==uid) (иначе безфильтровый запрос
    // отклонится); teacher/admin — безфильтровый (request-level ветка разрешает всё).
    match /lessons/{docId} {
      allow read:  if isSignedIn() && (
                     resource.data.studentId == request.auth.uid
                     || isAdmin()
                     || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'teacher'
                   );
      allow write: if isAdmin();
    }

    // ── Логи уроков: только admin ─────────────────────────────────────────────
    match /lessonLogs/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Платежи: только admin ─────────────────────────────────────────────────
    match /payments/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Недельный рейтинг: leaderboard/{weekId}/entries/{uid} ─────────────────
    // Защита от читерства (вариант B): пишет только владелец, points может
    // только расти и не больше чем на +200 за одну запись (потолок одной
    // действие = day_streak_7). Это не блокирует упорного читера, но обрезает
    // тривиальный DevTools-абюз.
    match /leaderboard/{weekId}/entries/{userId} {
      allow read:   if isSignedIn();
      allow create: if isOwner(userId)
                    && request.resource.data.uid == userId
                    && request.resource.data.points is int
                    && request.resource.data.points >= 0
                    && request.resource.data.points <= 200;
      allow update: if isOwner(userId)
                    && request.resource.data.uid == userId
                    && request.resource.data.points is int
                    && request.resource.data.points >= resource.data.points
                    && request.resource.data.points <= resource.data.points + 200;
      allow delete: if false;
    }

    // ── Доска (whiteboard): контент урока. Пишет ТОЛЬКО учитель (admin); читают
    // все залогиненные (ученик смотрит доску своего урока). Запись учеником
    // закрыта — в UI canvas readOnly для не-admin (LessonModal), теперь и в rules.
    match /wbImages/{docId}    { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /wbStrokes/{docId}   { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /whiteboards/{docId} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // ── Индивидуальные планы (уже закрыты выше) ──────────────────────────────
    // (individualPlans — см. выше в разделе прогресса)

    // ── Всё остальное — запрещено ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
